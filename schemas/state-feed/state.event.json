{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platform/contracts/state-feed/state.event",
  "title": "StateEvent",
  "description": "Event emitted over SSE by the state-feed (D029). Consumed by the dashboard, the 3D renderer, and the guest projection — the same schema, three renderers. Discriminate on the 'type' field.",
  "oneOf": [
    { "$ref": "#/definitions/ComponentHealthEvent" },
    { "$ref": "#/definitions/LoadEvent" },
    { "$ref": "#/definitions/CostTickEvent" },
    { "$ref": "#/definitions/CiRunEvent" },
    { "$ref": "#/definitions/AppStatusEvent" },
    { "$ref": "#/definitions/ActivityCountEvent" }
  ],
  "definitions": {
    "ComponentHealthEvent": {
      "title": "ComponentHealthEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "component.health" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/ComponentHealthPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "ComponentHealthPayload": {
      "title": "ComponentHealthPayload",
      "type": "object",
      "required": ["componentId", "status"],
      "additionalProperties": false,
      "properties": {
        "componentId": {
          "type": "string",
          "description": "Functional identifier of the hexagon or infrastructure component"
        },
        "status": {
          "type": "string",
          "enum": ["UP", "DOWN", "DEGRADED"],
          "description": "Current health status"
        },
        "details": {
          "type": "string",
          "description": "Optional human-readable detail about a non-UP status"
        }
      }
    },
    "LoadEvent": {
      "title": "LoadEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "load" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/LoadPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "LoadPayload": {
      "title": "LoadPayload",
      "type": "object",
      "required": ["componentId", "value"],
      "additionalProperties": false,
      "properties": {
        "componentId": {
          "type": "string",
          "description": "Functional identifier of the component being measured"
        },
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Load percentage (0–100)"
        },
        "metric": {
          "type": "string",
          "description": "What is being measured (cpu, memory, rps, etc.)",
          "examples": ["cpu", "memory", "rps"]
        }
      }
    },
    "CostTickEvent": {
      "title": "CostTickEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "cost.tick" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/CostTickPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "CostTickPayload": {
      "title": "CostTickPayload",
      "type": "object",
      "required": ["period", "totalCost"],
      "additionalProperties": false,
      "properties": {
        "period": {
          "type": "string",
          "description": "Billing period in YYYY-MM format",
          "pattern": "^\\d{4}-\\d{2}$",
          "examples": ["2026-07"]
        },
        "totalCost": {
          "type": "number",
          "minimum": 0,
          "description": "Total platform AI cost in USD for the period so far"
        },
        "breakdown": {
          "type": "object",
          "description": "Cost in USD keyed by appId or provider",
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "CiRunEvent": {
      "title": "CiRunEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "ci.run" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/CiRunPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "CiRunPayload": {
      "title": "CiRunPayload",
      "description": "Produced by ci-runner for each workflow_job phase transition.",
      "type": "object",
      "required": ["runId", "repo", "ref", "workflow", "jobName", "phase", "runnerLabels"],
      "additionalProperties": false,
      "properties": {
        "runId": {
          "type": "integer",
          "format": "int64",
          "description": "GitHub Actions workflow run ID."
        },
        "repo": {
          "type": "string",
          "description": "Full repo name (owner/repo)."
        },
        "ref": {
          "type": "string",
          "description": "Branch or tag that triggered the run."
        },
        "workflow": {
          "type": "string",
          "description": "Workflow name as reported by GitHub."
        },
        "jobName": {
          "type": "string",
          "description": "Specific job name within the workflow."
        },
        "phase": {
          "type": "string",
          "enum": ["queued", "in_progress", "completed"],
          "description": "Lifecycle phase matching the GitHub workflow_job action."
        },
        "conclusion": {
          "type": "string",
          "enum": ["success", "failure", "cancelled", "skipped", "timed_out"],
          "description": "Terminal outcome; present only when phase=completed."
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "runnerLabels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Labels on the runner that executed the job."
        }
      }
    },
    "AppStatusEvent": {
      "title": "AppStatusEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "app.status" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/AppStatusPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "AppStatusPayload": {
      "title": "AppStatusPayload",
      "type": "object",
      "required": ["appId", "status"],
      "additionalProperties": false,
      "properties": {
        "appId": {
          "type": "string",
          "description": "Functional app identifier as assigned by the control plane"
        },
        "status": {
          "type": "string",
          "enum": ["starting", "running", "degraded", "stopped"],
          "description": "Current runtime status of the app"
        },
        "version": {
          "type": "string",
          "description": "Deployed version (semver)"
        }
      }
    },
    "ActivityCountEvent": {
      "title": "ActivityCountEvent",
      "type": "object",
      "required": ["type", "timestamp", "payload"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "activity.count" },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when the event was produced"
        },
        "payload": { "$ref": "#/definitions/ActivityCountPayload" },
        "origin": { "$ref": "#/definitions/Origin" }
      }
    },
    "ActivityCountPayload": {
      "title": "ActivityCountPayload",
      "type": "object",
      "required": ["componentId", "activity", "count"],
      "additionalProperties": false,
      "properties": {
        "componentId": {
          "type": "string",
          "description": "Functional identifier of the emitting component"
        },
        "activity": {
          "type": "string",
          "description": "Machine-readable name of what is being counted",
          "examples": ["tool.call", "mail.summary", "scan.message", "scan.finding"]
        },
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of this activity SINCE THE LAST emission for this (componentId, activity) pair — a delta, not a cumulative total. Consumers aggregate across emissions."
        }
      }
    },
    "Origin": {
      "title": "Origin",
      "type": "string",
      "enum": ["host", "hub"],
      "description": "Which wall the event was produced on (D011). Optional — absent means host, preserving compatibility with producers that predate this field."
    }
  }
}
