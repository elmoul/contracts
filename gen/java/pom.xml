<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.platform</groupId>
    <artifactId>contracts</artifactId>
    <version>0.17.0</version>
    <packaging>jar</packaging>

    <name>platform-contracts</name>
    <description>
        Generated Java bindings for platform contracts.
        Do not edit by hand — regenerate from schemas/ using openapi-generator and jsonschema2pojo.
    </description>

    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <jackson.version>2.17.0</jackson.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
            <version>${jackson.version}</version>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <version>${jackson.version}</version>
        </dependency>
        <dependency>
            <groupId>jakarta.validation</groupId>
            <artifactId>jakarta.validation-api</artifactId>
            <version>3.0.2</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>jakarta.annotation</groupId>
            <artifactId>jakarta.annotation-api</artifactId>
            <version>2.1.1</version>
            <optional>true</optional>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>5.10.2</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.datatype</groupId>
            <artifactId>jackson-datatype-jsr310</artifactId>
            <version>${jackson.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
            </plugin>
            <!-- JSON Schema → Java: usage.event and state.event -->
            <plugin>
                <groupId>org.jsonschema2pojo</groupId>
                <artifactId>jsonschema2pojo-maven-plugin</artifactId>
                <version>1.2.1</version>
                <configuration>
                    <sourcePaths>
                        <!-- state.event.json uses oneOf at root; jsonschema2pojo cannot generate
                             per-variant classes from a oneOf union. State event Java classes are
                             generated via openapi-generator from schemas/state-feed/state-event-java.yaml. -->
                        <sourcePath>${project.basedir}/../../schemas/app/usage.event.json</sourcePath>
                        <sourcePath>${project.basedir}/../../schemas/app/dimension.event.json</sourcePath>
                        <!-- telemetry.json's root is the Loki structured-log-record shape
                             (TelemetryLogRecord); its $defs/PrometheusMetricLabels and
                             $defs/MetricName are deliberately unreferenced from root (Prometheus
                             labels are attached via the metrics client API, never built as a JSON
                             document) and so generate no Java class — documentation/validation-only,
                             consistent with the schema's own description. -->
                        <sourcePath>${project.basedir}/../../schemas/app/telemetry.json</sourcePath>
                    </sourcePaths>
                    <targetPackage>io.platform.contracts.events</targetPackage>
                    <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                    <annotationStyle>jackson2</annotationStyle>
                    <includeAdditionalProperties>false</includeAdditionalProperties>
                    <includeConstructors>true</includeConstructors>
                    <generateBuilders>false</generateBuilders>
                    <useTitleAsClassname>true</useTitleAsClassname>
                    <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                    <useJakartaValidation>true</useJakartaValidation>
                </configuration>
                <executions>
                    <execution>
                        <id>events</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>ci-runner</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <sourcePaths>
                                <sourcePath>${project.basedir}/../../schemas/ci-runner/build-command.yaml</sourcePath>
                                <sourcePath>${project.basedir}/../../schemas/ci-runner/build-result.yaml</sourcePath>
                            </sourcePaths>
                            <targetPackage>io.platform.contracts.cirunner</targetPackage>
                            <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                            <sourceType>yamlschema</sourceType>
                            <annotationStyle>jackson2</annotationStyle>
                            <includeAdditionalProperties>false</includeAdditionalProperties>
                            <includeConstructors>true</includeConstructors>
                            <generateBuilders>false</generateBuilders>
                            <useTitleAsClassname>true</useTitleAsClassname>
                            <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                            <useJakartaValidation>true</useJakartaValidation>
                        </configuration>
                    </execution>
                    <execution>
                        <id>control-plane</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <sourcePaths>
                                <sourcePath>${project.basedir}/../../schemas/control-plane/hexagon.descriptor.json</sourcePath>
                                <sourcePath>${project.basedir}/../../schemas/control-plane/registry.entry.json</sourcePath>
                            </sourcePaths>
                            <targetPackage>io.platform.contracts.controlplane</targetPackage>
                            <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                            <annotationStyle>jackson2</annotationStyle>
                            <includeAdditionalProperties>false</includeAdditionalProperties>
                            <includeConstructors>true</includeConstructors>
                            <generateBuilders>false</generateBuilders>
                            <useTitleAsClassname>true</useTitleAsClassname>
                            <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                            <useJakartaValidation>true</useJakartaValidation>
                        </configuration>
                    </execution>
                    <execution>
                        <id>connector</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <sourcePaths>
                                <sourcePath>${project.basedir}/../../schemas/connector/connector.vocabulary.json</sourcePath>
                                <sourcePath>${project.basedir}/../../schemas/connector/connector.invoke.request.json</sourcePath>
                                <sourcePath>${project.basedir}/../../schemas/connector/connector.invoke.response.json</sourcePath>
                            </sourcePaths>
                            <targetPackage>io.platform.contracts.connector</targetPackage>
                            <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                            <annotationStyle>jackson2</annotationStyle>
                            <includeAdditionalProperties>false</includeAdditionalProperties>
                            <includeConstructors>true</includeConstructors>
                            <generateBuilders>false</generateBuilders>
                            <useTitleAsClassname>true</useTitleAsClassname>
                            <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                            <useJakartaValidation>true</useJakartaValidation>
                        </configuration>
                    </execution>
                    <execution>
                        <id>demand-coordinator</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <sourcePaths>
                                <sourcePath>${project.basedir}/../../schemas/demand-coordinator/demand.json</sourcePath>
                                <sourcePath>${project.basedir}/../../schemas/demand-coordinator/demand.fulfillment.json</sourcePath>
                            </sourcePaths>
                            <targetPackage>io.platform.contracts.demandcoordinator</targetPackage>
                            <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                            <annotationStyle>jackson2</annotationStyle>
                            <includeAdditionalProperties>false</includeAdditionalProperties>
                            <includeConstructors>true</includeConstructors>
                            <generateBuilders>false</generateBuilders>
                            <useTitleAsClassname>true</useTitleAsClassname>
                            <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                            <useJakartaValidation>true</useJakartaValidation>
                        </configuration>
                    </execution>
                    <execution>
                        <id>ai-gateway-model-manifest</id>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <sourcePaths>
                                <sourcePath>${project.basedir}/../../schemas/ai-gateway/model-manifest.json</sourcePath>
                            </sourcePaths>
                            <!-- Same package as AiRequest/AiResponse (generated via openapi-generator from
                                 request.yaml/preflight.yaml); model-manifest.json is a plain JSON Schema, not an
                                 OpenAPI document, so it goes through jsonschema2pojo like control-plane/connector/
                                 demand-coordinator, but shares the ai-gateway package since it's the same contract
                                 group. No class-name collision: AiModelManifest/CapabilityDeclaration vs
                                 AiRequest/AiResponse/BlockedResponse. -->
                            <targetPackage>io.platform.contracts.aigateway</targetPackage>
                            <outputDirectory>${project.basedir}/target/generated-sources/jsonschema2pojo</outputDirectory>
                            <annotationStyle>jackson2</annotationStyle>
                            <!-- Override of this plugin's project-wide includeAdditionalProperties=false, for this
                                 execution only: model-manifest.json's "capabilities" property is a pure dictionary
                                 (an object with no "properties" of its own, only "additionalProperties": {$ref:
                                 CapabilityDeclaration}). jsonschema2pojo 1.2.1 only emits the Map-typed
                                 additionalProperties field (and only then walks the $ref to generate
                                 CapabilityDeclaration) when includeAdditionalProperties is true; with the
                                 project-wide false it silently produced an empty stub class and never generated
                                 CapabilityDeclaration at all (confirmed contracts v0.9.0 defect). Every schema in
                                 this file that has real "properties" also declares "additionalProperties": false
                                 explicitly, which jsonschema2pojo honors regardless of this flag (verified: no
                                 spurious additionalProperties field appears on AiModelManifest or
                                 CapabilityDeclaration), so this override only takes effect on the one genuine
                                 dictionary type. Wire format is unaffected: the generated Capabilities wrapper's
                                 map is exposed via @JsonAnyGetter/@JsonAnySetter, which Jackson (de)serializes
                                 flattened into the JSON object exactly like a plain map, not nested under an
                                 "additionalProperties" key. -->
                            <includeAdditionalProperties>true</includeAdditionalProperties>
                            <includeConstructors>true</includeConstructors>
                            <generateBuilders>false</generateBuilders>
                            <useTitleAsClassname>true</useTitleAsClassname>
                            <dateTimeType>java.time.OffsetDateTime</dateTimeType>
                            <useJakartaValidation>true</useJakartaValidation>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
